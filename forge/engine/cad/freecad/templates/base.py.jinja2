def create_document(name: str):
    """Create or get FreeCAD document."""
    if FreeCAD.ActiveDocument:
        doc = FreeCAD.ActiveDocument
    else:
        doc = FreeCAD.newDocument(name)
    return doc


def create_body(doc, name: str):
    """Create a PartDesign Body."""
    body = doc.addObject("PartDesign::Body", name)
    return body


def create_box(
    length: float,
    width: float,
    height: float,
    position: tuple = (0, 0, 0),
    name: str = "Box"
):
    """
    Create a box solid.

    Args:
        length: X dimension (mm)
        width: Y dimension (mm)
        height: Z dimension (mm)
        position: Center position (x, y, z) in mm
        name: Feature name

    Returns:
        Part.Shape box solid
    """
    # Create box centered at origin
    box = Part.makeBox(length, width, height)

    # Move to center position
    x_offset = position[0] - length / 2
    y_offset = position[1] - width / 2
    z_offset = position[2] - height / 2

    box.translate(Vector(x_offset, y_offset, z_offset))

    return box


def create_cylinder(
    radius: float,
    height: float,
    position: tuple = (0, 0, 0),
    inner_radius: float = 0,
    name: str = "Cylinder"
):
    """
    Create a cylinder (or tube if inner_radius > 0).

    Args:
        radius: Outer radius (mm)
        height: Z dimension (mm)
        position: Center position (x, y, z) in mm
        inner_radius: Inner radius for hollow cylinder (mm), 0 for solid
        name: Feature name

    Returns:
        Part.Shape cylinder or tube solid
    """
    # Create outer cylinder centered at z=0
    outer = Part.makeCylinder(radius, height)
    outer.translate(Vector(0, 0, -height / 2))

    if inner_radius > 0 and inner_radius < radius:
        # Create inner cylinder and subtract
        inner = Part.makeCylinder(inner_radius, height)
        inner.translate(Vector(0, 0, -height / 2))
        result = outer.cut(inner)
    else:
        result = outer

    # Move to center position
    result.translate(Vector(position[0], position[1], position[2]))

    return result


def add_solid_to_document(doc, solid, name: str, color: tuple = None, transparency: int = 0):
    """
    Add a solid shape to the document.

    Args:
        doc: FreeCAD document
        solid: Part.Shape solid
        name: Object name
        color: RGB color tuple (0-1 range)
        transparency: Transparency percentage (0-100)

    Returns:
        Feature object
    """
    feature = doc.addObject("Part::Feature", name)
    feature.Shape = solid

    # Set view properties if GUI is available
    if FreeCAD.GuiUp and hasattr(feature, "ViewObject"):
        if color is not None:
            feature.ViewObject.ShapeColor = color
        feature.ViewObject.Transparency = transparency

    return feature


def create_part_group(doc, name: str):
    """Create a group to organize parts."""
    group = doc.addObject("App::DocumentObjectGroup", name)
    return group


