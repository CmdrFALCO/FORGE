{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cylindrical Cell Definition Schema",
  "description": "JSON Schema for validating cylindrical battery cell definitions (18650, 21700, 4680 formats). Supports both traditional tab and tabless (4680-style) designs with jelly roll winding.",
  "type": "object",
  "required": [
    "geometry",
    "winding",
    "electrochemistry",
    "housing"
  ],
  "additionalProperties": true,
  "properties": {
    "_meta": {
      "type": "object",
      "description": "Metadata about the cell definition",
      "properties": {
        "cell_type": {
          "type": "string",
          "const": "cylindrical"
        },
        "format": {
          "type": "string",
          "enum": ["18650", "21700", "4680", "custom"],
          "description": "Standard cell format or custom"
        },
        "design_intent": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "geometry": {
      "type": "object",
      "description": "External can dimensions",
      "required": [
        "diameter_mm",
        "length_mm",
        "can_wall_thickness_mm",
        "can_bottom_thickness_mm",
        "header_height_mm"
      ],
      "additionalProperties": false,
      "properties": {
        "diameter_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 10.0,
              "maximum": 60.0,
              "description": "External can diameter (e.g., 18 for 18650, 21 for 21700, 46 for 4680)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "length_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 30.0,
              "maximum": 100.0,
              "description": "External can length (e.g., 65 for 18650, 70 for 21700, 80 for 4680)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "can_wall_thickness_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.15,
              "maximum": 0.6,
              "description": "Can body wall thickness (typically 0.2-0.4mm)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "can_bottom_thickness_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.2,
              "maximum": 1.0,
              "description": "Can bottom plate thickness"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "header_height_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 2.0,
              "maximum": 6.0,
              "description": "Top assembly/header height"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    },
    "winding": {
      "type": "object",
      "description": "Jelly roll winding configuration",
      "required": [
        "mandrel_diameter_mm",
        "winding_clearance_mm",
        "winding_tension_factor",
        "tab_type"
      ],
      "additionalProperties": false,
      "properties": {
        "mandrel_diameter_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 1.5,
              "maximum": 8.0,
              "description": "Inner core/mandrel diameter (typically 2-5mm)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "winding_clearance_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.05,
              "maximum": 0.5,
              "description": "Gap between jelly roll outer diameter and can wall"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "winding_tension_factor": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.90,
              "maximum": 1.0,
              "description": "Compression factor (1.0 = no compression, 0.95 = 5% compressed)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "tab_type": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["traditional", "tabless"],
              "description": "Traditional tabs or tabless (4680-style foil extensions)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "anode_tab_width_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 2.0,
              "maximum": 15.0,
              "description": "Anode tab width (traditional only)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "anode_tab_thickness_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.05,
              "maximum": 0.3,
              "description": "Anode tab thickness (traditional only)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "cathode_tab_width_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 2.0,
              "maximum": 15.0,
              "description": "Cathode tab width (traditional only)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "cathode_tab_thickness_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.05,
              "maximum": 0.3,
              "description": "Cathode tab thickness (traditional only)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "anode_foil_extension_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 1.0,
              "maximum": 8.0,
              "description": "Anode foil extension for tabless design (typically 2-5mm)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "cathode_foil_extension_mm": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 1.0,
              "maximum": 8.0,
              "description": "Cathode foil extension for tabless design (typically 2-5mm)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    },
    "electrochemistry": {
      "type": "object",
      "required": [
        "cathode",
        "anode",
        "separator",
        "electrolyte"
      ],
      "additionalProperties": false,
      "properties": {
        "cathode": {
          "type": "object",
          "required": [
            "material_name",
            "loading_mg_cm2",
            "rev_spec_capacity_mahg",
            "collector_thickness_um",
            "coating_thickness_0pct_um",
            "coating_thickness_100pct_um",
            "porosity_pct"
          ],
          "additionalProperties": false,
          "properties": {
            "material_name": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "loading_mg_cm2": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 5.0,
                  "maximum": 30.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "rev_spec_capacity_mahg": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 140.0,
                  "maximum": 220.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "collector_thickness_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 8.0,
                  "maximum": 20.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_thickness_0pct_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 40.0,
                  "maximum": 100.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_thickness_100pct_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 40.0,
                  "maximum": 100.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "porosity_pct": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 15.0,
                  "maximum": 40.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_density_gcm3": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 2.0,
                  "maximum": 5.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        },
        "anode": {
          "type": "object",
          "required": [
            "material_name",
            "loading_mg_cm2",
            "rev_spec_capacity_mahg",
            "collector_thickness_um",
            "coating_thickness_0pct_um",
            "coating_thickness_100pct_um",
            "porosity_pct",
            "np_ratio"
          ],
          "additionalProperties": false,
          "properties": {
            "material_name": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "loading_mg_cm2": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 5.0,
                  "maximum": 20.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "rev_spec_capacity_mahg": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 300.0,
                  "maximum": 500.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "collector_thickness_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 4.0,
                  "maximum": 12.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_thickness_0pct_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 40.0,
                  "maximum": 150.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_thickness_100pct_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 40.0,
                  "maximum": 150.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "porosity_pct": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 20.0,
                  "maximum": 45.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "np_ratio": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 1.05,
                  "maximum": 1.5
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "coating_density_gcm3": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 1.5,
                  "maximum": 3.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        },
        "separator": {
          "type": "object",
          "required": [
            "material_name",
            "thickness_um",
            "porosity_pct",
            "areal_weight_mgcm2"
          ],
          "additionalProperties": false,
          "properties": {
            "material_name": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "thickness_um": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 9.0,
                  "maximum": 25.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "porosity_pct": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 30.0,
                  "maximum": 55.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "areal_weight_mgcm2": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 0.8,
                  "maximum": 3.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        },
        "electrolyte": {
          "type": "object",
          "required": [
            "material_name",
            "density_g_cm3",
            "excess_factor"
          ],
          "additionalProperties": false,
          "properties": {
            "material_name": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "density_g_cm3": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 1.1,
                  "maximum": 1.4
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "excess_factor": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 1.0,
                  "maximum": 1.3
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        }
      }
    },
    "housing": {
      "type": "object",
      "description": "Can housing and header configuration",
      "required": [
        "can_material"
      ],
      "additionalProperties": false,
      "properties": {
        "can_material": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["steel", "aluminum", "nickel_plated_steel"],
              "description": "Can body material"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "header_mass_g": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.5,
              "maximum": 10.0,
              "description": "Total header assembly mass (simplified specification)"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "bottom_insulator_mass_g": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.01,
              "maximum": 1.0,
              "description": "Bottom insulator disc mass"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "top_insulator_mass_g": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0.01,
              "maximum": 1.0,
              "description": "Top insulator ring mass"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    },
    "tabs": {
      "type": "object",
      "description": "Tab configurations (required for traditional tab_type)",
      "additionalProperties": false,
      "properties": {
        "cathode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "material": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "width_mm": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 2.0,
                  "maximum": 15.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "thickness_mm": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 0.05,
                  "maximum": 0.3
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        },
        "anode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "material": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "width_mm": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 2.0,
                  "maximum": 15.0
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            },
            "thickness_mm": {
              "oneOf": [
                {
                  "type": "number",
                  "minimum": 0.05,
                  "maximum": 0.3
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          }
        }
      }
    }
  }
}
