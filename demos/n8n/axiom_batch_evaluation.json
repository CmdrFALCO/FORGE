              "type": "string"
            },
            {
              "id": "95a721ba-2639-4ddf-b3d7-20a8208cf2ce",
              "name": "thesis_argument",
              "value": "={{ $json.thesis_argument }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    }
