      "typeVersion": 4.2,
      "position": [
        920,
        460
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FORGE_API_URL || \"http://localhost:8000\" }}/api/v1/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { prompt: $json.prompt, backend: $json.backend } }}",
        "options": {}
      }
    },
    {
      "id": "c4a367ed-51df-41a4-9789-5820e3d51134",
      "name": "Unsupervised - Parse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1140,
        460
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FORGE_API_URL || \"http://localhost:8000\" }}/api/v1/parse",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { raw_yaml: $json.data?.raw_yaml || '' } }}",
        "options": {}
      }
    },
    {
      "id": "d10d1dde-6309-4171-a495-392cae75159e",
      "name": "Unsupervised - Build Validate Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        460
      ],
      "parameters": {
        "jsCode": "const parsed = $json.data?.parsed_spec ?? {};\nconst rawType = parsed?._meta?.cell_type ?? parsed?.cell_type ?? 'prismatic';\nreturn [{\n  json: {\n    cell_type: String(rawType).toLowerCase(),\n    spec: parsed,\n  },\n}];"
      }
    },
    {
      "id": "309d8b50-fd45-4569-b397-524c2bb4528c",
      "name": "Unsupervised - Validate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1580,
        460
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FORGE_API_URL || \"http://localhost:8000\" }}/api/v1/validate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { cell_type: $json.cell_type, spec: $json.spec } }}",
        "options": {}
      }
    },
    {
      "id": "c5662652-6443-4bc3-a035-20888e453b39",
      "name": "Unsupervised - Record",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1800,
        460
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "fb37a079-aeef-4dcc-818d-e216303372b2",
              "name": "iteration",
              "value": "={{ $('Build Iteration Items').item.json.iteration }}",
              "type": "number"
            },
            {
              "id": "53822483-7346-40c8-b7dd-2cfec67b2bfc",
              "name": "unsupervised_valid",
              "value": "={{ Boolean($json.data?.valid) }}",
              "type": "boolean"
            },
            {
              "id": "75fce639-8d57-4efe-9f5d-a6c2cfdcadea",
              "name": "unsupervised_error_count",
              "value": "={{ Array.isArray($json.data?.errors) ? $json.data.errors.length : 0 }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "5532839d-4d00-41de-81e5-27bc37bb43a6",
      "name": "Merge Iteration Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.1,
      "position": [
        2020,
        300
      ],
      "parameters": {
        "mode": "mergeByIndex"
      }
    },
    {
      "id": "cd69ce05-66cc-4747-aad2-2fcb8184a9bd",
      "name": "Final Statistics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2240,
        300
      ],
      "parameters": {
        "jsCode": "const rows = $input.all().map((item) => item.json);\nconst total = rows.length;\nconst supervisedPass = rows.filter((r) => r.supervised_valid === true).length;\nconst unsupervisedPass = rows.filter((r) => r.unsupervised_valid === true).length;\nconst supervisedFail = total - supervisedPass;\nconst unsupervisedFail = total - unsupervisedPass;\n\nconst supervisedFailRate = total > 0 ? (supervisedFail / total) * 100 : 0;\nconst unsupervisedFailRate = total > 0 ? (unsupervisedFail / total) * 100 : 0;\n\nconst report = {\n  total_iterations: total,\n  supervised: {\n    passed: supervisedPass,\n    failed: supervisedFail,\n    pass_rate: total > 0 ? `${((supervisedPass / total) * 100).toFixed(1)}%` : '0.0%',\n    failure_rate: `${supervisedFailRate.toFixed(1)}%`,\n  },\n  unsupervised: {\n    passed: unsupervisedPass,\n    failed: unsupervisedFail,\n    pass_rate: total > 0 ? `${((unsupervisedPass / total) * 100).toFixed(1)}%` : '0.0%',\n    failure_rate: `${unsupervisedFailRate.toFixed(1)}%`,\n  },\n  improvement: {\n    failure_rate_reduction: `${(unsupervisedFailRate - supervisedFailRate).toFixed(1)} percentage points`,\n  },\n  thesis_argument:\n    supervisedPass > unsupervisedPass\n      ? 'AXIOM supervision reduced constraint failures versus unsupervised generation in this batch.'\n      : 'Results inconclusive; increase iteration count or vary prompts for stronger evidence.',\n  per_iteration: rows,\n};\n\nreturn [{ json: report }];"
      }
    },
    {
      "id": "7ad45bb0-a3b0-4263-a3f1-c83cdd039eae",
      "name": "Set Report Output",
