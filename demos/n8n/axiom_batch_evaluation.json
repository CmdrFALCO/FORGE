      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        460,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ace6ec3d-d223-4028-a4b6-56a4c6d083f0",
              "name": "prompt",
              "value": "Design a 50Ah prismatic NMC811 cell for automotive fast-charging applications",
              "type": "string"
            },
            {
              "id": "b2926d65-2f15-49dd-a520-623450b22702",
              "name": "backend",
              "value": "={{ $env.FORGE_LLM_BACKEND || \"ollama\" }}",
              "type": "string"
            },
            {
              "id": "0f266eb2-de82-4648-b841-74f1ee7c93ae",
              "name": "total_iterations",
              "value": 10,
              "type": "number"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "4cc173fc-c2df-400a-b3ca-83b3890d3473",
      "name": "Build Iteration Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "jsCode": "const cfg = $input.first().json;\nconst total = Number(cfg.total_iterations ?? 10);\nconst items = [];\nfor (let i = 0; i < total; i += 1) {\n  items.push({\n    json: {\n      iteration: i + 1,\n      prompt: cfg.prompt,\n      backend: cfg.backend,\n    },\n  });\n}\nreturn items;"
      }
    },
    {
      "id": "c5dd4018-a018-4eac-89d6-ab3af2d5a870",
      "name": "Supervised - Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        920,
        140
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FORGE_API_URL || \"http://localhost:8000\" }}/api/v1/pipeline",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { prompt: $json.prompt, backend: $json.backend, max_retries: 3 } }}",
        "options": {}
      }
    },
    {
      "id": "727ab083-f46d-42cb-bac3-a3723143d6ef",
      "name": "Supervised - Record",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1140,
        140
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "5fbeb5ed-2ce3-412c-854d-c68419861b91",
              "name": "iteration",
              "value": "={{ $('Build Iteration Items').item.json.iteration }}",
              "type": "number"
            },
            {
              "id": "c8f05125-c31a-4ba0-9ba3-2e8efa948856",
              "name": "supervised_valid",
              "value": "={{ Boolean($json.data?.final_valid) }}",
              "type": "boolean"
            },
            {
              "id": "6e86c0ba-c8d3-428b-a02c-313f6ebcce3c",
              "name": "supervised_attempts",
              "value": "={{ Number($json.data?.total_attempts || 0) }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "ffc99013-b6b2-4fe9-b5d6-0c8ab288bc41",
